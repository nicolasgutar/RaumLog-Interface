modules = ["nodejs-24"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/raumlog"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/start-cloudsql-proxy.sh"
waitForPort = 5432

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5001 pnpm --filter @workspace/api-server dev"
waitForPort = 5001

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 BASE_PATH='/' pnpm --filter @workspace/raumlog dev"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.shared]
GCP_PROJECT_ID = "raumlog-e5b0f"
GCS_PRIVATE_BUCKET = "raumlog-kyc-private"
GCS_PUBLIC_BUCKET = "raumlog-spaces-public"
VITE_FIREBASE_API_KEY = "AIzaSyCaowh1eT4i0B0FidnD8RIMfhOOr075KeA"
VITE_FIREBASE_AUTH_DOMAIN = "raumlog-e5b0f.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID = "raumlog-e5b0f"
VITE_FIREBASE_STORAGE_BUCKET = "raumlog-e5b0f.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID = "315182199687"
