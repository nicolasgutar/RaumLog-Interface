modules = ["nodejs-24"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/raumlog"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/start-cloudsql-proxy.sh"
waitForPort = 5432

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5001 pnpm --filter @workspace/api-server dev"
waitForPort = 5001

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 BASE_PATH='/' pnpm --filter @workspace/raumlog dev"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.shared]
JWT_SECRET = "dc893f20c018e6818fb588916d72ced6b691c531c2a63d43b6675448c594527e"
